@page
@model ConsultantPlatform.Web.Pages.CustomerDocumentsModel
@{
    ViewData["Title"] = "Customer Documents";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="mb-0">Documents</h1>
        <div id="customerSubtitle" class="text-muted"></div>
    </div>

    <a class="btn btn-primary" href="/Customers">Back to Customers</a>
</div>


<div class="mb-3 d-flex gap-2">
    <a id="btnCreateDoc" class="btn btn-success" href="#" style="display:none;">Create document</a>
</div>

<div class="table-responsive" style="overflow: visible;">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th style="width:190px;">Type</th>
                <th>Notes</th>
                <th style="width:240px;">File</th>
                <th style="width:170px;">Created</th>
                <th id="thManage" class="text-end" style="display:none; width:140px;">Manage</th>
            </tr>
        </thead>
        <tbody id="docsBody"></tbody>
    </table>
</div>

@section Scripts {
    <script>
        const apiBase = window.auth.apiBase;
        let isAdmin = false;

        function qs(name) {
            const url = new URL(window.location.href);
            return url.searchParams.get(name);
        }

        

        function fmtDate(iso) {
            if (!iso) return "-";
            const d = new Date(iso);
            if (isNaN(d)) return "-";
            return d.toLocaleDateString();
        }

        function truncate(text, max = 80) {
            if (!text) return "-";
            const s = String(text);
            return s.length > max ? s.substring(0, max) + "…" : s;
        }

        function humanizeEnum(value) {
            if (!value) return "";
            return String(value).replace(/([a-z])([A-Z])/g, "$1 $2").trim();
        }

        async function loadCustomer(customerId) {
            const res = await fetch(`${apiBase}/api/customers/${customerId}`, { credentials: "include" });
            if (!res.ok) return null;
            return await res.json();
        }

        async function loadDocuments(customerId) {
            const res = await fetch(`${apiBase}/api/customers/${customerId}/documents`, { credentials: "include", cache: "no-store" });
            if (!res.ok) return null;
            const data = await res.json();
            return Array.isArray(data) ? data : [];
        }

        function renderDocuments(docs) {
            const tbody = document.getElementById("docsBody");
            tbody.innerHTML = "";

            if (!Array.isArray(docs) || docs.length === 0) {
                tbody.innerHTML = `<tr><td colspan="${isAdmin ? 6 : 5}" class="text-muted">No documents yet.</td></tr>`;
                return;
            }

            for (const d of docs) {
                const tr = document.createElement("tr");

                const tdName = document.createElement("td");
                tdName.textContent = d.name ?? "";

                const tdType = document.createElement("td");
                tdType.textContent = humanizeEnum(d.type ?? "");

                const tdNotes = document.createElement("td");
                tdNotes.textContent = truncate(d.notes, 120);

                const tdFile = document.createElement("td");
                if (d.originalFileName) {
                    const a = document.createElement("a");
                    a.href = `${apiBase}/api/documents/${d.id}/preview`;
                    a.target = "_blank";
                    a.rel = "noopener";
                    a.textContent = d.originalFileName;
                    tdFile.appendChild(a);
                } else {
                    tdFile.textContent = "-";
                }

                const tdCreated = document.createElement("td");
                tdCreated.textContent = fmtDate(d.createdAtUtc);

                tr.appendChild(tdName);
                tr.appendChild(tdType);
                tr.appendChild(tdNotes);
                tr.appendChild(tdFile);
                tr.appendChild(tdCreated);

                if (isAdmin) {
                    const tdManage = document.createElement("td");
                    tdManage.className = "text-end";

                    const group = document.createElement("div");
                    group.className = "btn-group";

                    const btnToggle = document.createElement("button");
                    btnToggle.type = "button";
                    btnToggle.className = "btn btn-sm btn-secondary dropdown-toggle";
                    btnToggle.setAttribute("data-bs-toggle", "dropdown");
                    btnToggle.setAttribute("data-bs-display", "static");
                    btnToggle.textContent = "Manage";

                    const menu = document.createElement("ul");
                    menu.className = "dropdown-menu dropdown-menu-end";

                    // Download (only if file exists)
                    if (d.originalFileName) {
                        const liDown = document.createElement("li");
                        const aDown = document.createElement("a");
                        aDown.className = "dropdown-item";
                        aDown.textContent = "Download";
                        aDown.href = `${apiBase}/api/documents/${d.id}/download`;
                        aDown.target = "_blank";
                        liDown.appendChild(aDown);
                        menu.appendChild(liDown);
                    }

                    const liDelete = document.createElement("li");
                    const btnDelete = document.createElement("button");
                    btnDelete.type = "button";
                    btnDelete.className = "dropdown-item text-danger";
                    btnDelete.textContent = "Delete";
                    btnDelete.addEventListener("click", async () => {
                        await deleteDocument(d.id);
                    });
                    liDelete.appendChild(btnDelete);
                    menu.appendChild(liDelete);

                    group.appendChild(btnToggle);
                    group.appendChild(menu);
                    tdManage.appendChild(group);

                    tr.appendChild(tdManage);
                }

                tbody.appendChild(tr);
            }
        }

        async function deleteDocument(docId) {
            const confirmed = await window.notifications.confirmAction(
                "Are you sure you want to delete this document?"
            );

            if (!confirmed) return;

            try {
                const res = await fetch(`${apiBase}/api/documents/${docId}`, {
                    method: "DELETE",
                    credentials: "include"
                });

                if (!res.ok) {
                    const errorMessage = await window.auth.getErrorMessage(res);
                    window.notifications.showError(errorMessage);
                    return;
                }

                window.notifications.showSuccess("Document deleted successfully.");

                const customerId = Number(qs("id"));
                const docs = await loadDocuments(customerId);
                renderDocuments(docs);
            }
            catch {
                window.notifications.showError("An unexpected error occurred.");
            }
        }

        (async () => {
            try {
                if (window.auth && !window.currentUser) {
                    await window.auth.initNavbar();
                }

                const customerIdRaw = qs("id");
                const customerId = Number(customerIdRaw);

                if (!customerIdRaw || Number.isNaN(customerId) || customerId <= 0) {
                    window.notifications.showError("Invalid customer id in URL.");
                    return;
                }

                isAdmin = !!(window.auth && window.auth.isAdmin && window.auth.isAdmin(window.currentUser));
                document.getElementById("thManage").style.display = isAdmin ? "" : "none";

                const btnCreate = document.getElementById("btnCreateDoc");
                btnCreate.href = `/DocumentCreate?customerId=${customerId}`;
                btnCreate.style.display = isAdmin ? "inline-block" : "none";

                const cust = await loadCustomer(customerId);
                if (cust) {
                    document.getElementById("customerSubtitle").textContent =
                        `${cust.name ?? ""} (${cust.email ?? "No email"})`;
                }

                const docs = await loadDocuments(customerId);
                if (docs === null) {
                    window.notifications.showError("Could not load documents.");
                    return;
                }

                renderDocuments(docs);
            }
            catch {
                window.notifications.showError("An unexpected error occurred.");
            }
        })();
    </script>
}
